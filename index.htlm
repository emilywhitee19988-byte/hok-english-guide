
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HOK English Guide - Complete Tier List & Counters</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: #e2e8f0;
      min-height: 100vh;
      padding: 20px;
    }
    
    .container {
      max-width: 1400px;
      margin: 0 auto;
    }
    
    /* View management */
    .view {
      display: none;
    }
    
    .view.active {
      display: block;
    }
    
    /* Header */
    .header {
      text-align: center;
      margin-bottom: 40px;
      padding: 30px 20px;
      background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(59, 130, 246, 0.3);
    }
    
    .header h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    
    .header p {
      font-size: 1.1rem;
      color: #bfdbfe;
    }
    
    .patch-info {
      display: inline-block;
      margin-top: 15px;
      padding: 8px 16px;
      background: rgba(255,255,255,0.1);
      border-radius: 20px;
      font-size: 0.9rem;
      backdrop-filter: blur(10px);
    }
    
    /* Back Button */
    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: rgba(30, 41, 59, 0.6);
      border: 2px solid #334155;
      border-radius: 10px;
      color: #e2e8f0;
      text-decoration: none;
      margin-bottom: 20px;
      transition: all 0.3s;
      cursor: pointer;
      border: none;
      font-size: 1rem;
    }
    
    .back-btn:hover {
      background: rgba(51, 65, 85, 0.8);
      border-color: #3b82f6;
    }
    
    /* Controls */
    .controls {
      display: flex;
      gap: 15px;
      margin-bottom: 30px;
      flex-wrap: wrap;
      background: rgba(30, 41, 59, 0.6);
      padding: 20px;
      border-radius: 15px;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(148, 163, 184, 0.1);
    }
    
    .search-box {
      flex: 1;
      min-width: 250px;
    }
    
    .search-box input {
      width: 100%;
      padding: 12px 20px;
      border: 2px solid #334155;
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.8);
      color: white;
      font-size: 1rem;
      transition: all 0.3s;
    }
    
    .search-box input:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    
    .search-box input::placeholder {
      color: #64748b;
    }
    
    .filter-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    
    .filter-btn {
      padding: 10px 20px;
      border: 2px solid #334155;
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.8);
      color: #e2e8f0;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: 600;
      font-size: 0.9rem;
    }
    
    .filter-btn:hover {
      background: rgba(51, 65, 85, 0.8);
      border-color: #475569;
    }
    
    .filter-btn.active {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      border-color: #3b82f6;
      color: white;
    }
    
    /* Tier Section */
    .tier-section {
      margin-bottom: 30px;
      background: rgba(30, 41, 59, 0.4);
      border-radius: 15px;
      overflow: hidden;
      border: 2px solid rgba(148, 163, 184, 0.1);
    }
    
    .tier-header {
      padding: 15px 25px;
      font-size: 1.5rem;
      font-weight: bold;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .tier-s { background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%); }
    .tier-a { background: linear-gradient(135deg, #ea580c 0%, #f97316 100%); }
    .tier-b { background: linear-gradient(135deg, #eab308 0%, #facc15 100%); color: #0f172a; }
    .tier-c { background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%); }
    
    .tier-content {
      padding: 20px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 15px;
    }
    
    /* Hero Card */
    .hero-card {
      background: linear-gradient(145deg, #1e293b 0%, #0f172a 100%);
      border: 2px solid #334155;
      border-radius: 12px;
      padding: 15px;
      cursor: pointer;
      transition: all 0.3s;
      text-align: center;
      position: relative;
    }
    
    .hero-card:hover {
      transform: translateY(-5px);
      border-color: #3b82f6;
      box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
    }
    
    .hero-avatar {
      width: 80px;
      height: 80px;
      margin: 0 auto 10px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: bold;
      background: linear-gradient(135deg, #334155 0%, #1e293b 100%);
      border: 3px solid #475569;
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }
    
    .hero-name-en {
      font-size: 1rem;
      font-weight: bold;
      margin-bottom: 3px;
      color: #f1f5f9;
    }
    
    .hero-name-alt {
      font-size: 0.75rem;
      color: #60a5fa;
      margin-bottom: 3px;
      font-style: italic;
    }
    
    .hero-name-cn {
      font-size: 0.8rem;
      color: #94a3b8;
      margin-bottom: 8px;
    }
    
    .hero-role {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
      margin-top: 5px;
    }
    
    /* Role Colors */
    .role-tank { background: #1e40af; color: white; }
    .role-fighter { background: #dc2626; color: white; }
    .role-assassin { background: #7c3aed; color: white; }
    .role-mage { background: #2563eb; color: white; }
    .role-marksman { background: #ea580c; color: white; }
    .role-support { background: #059669; color: white; }
    
    .hero-stats {
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid #334155;
      font-size: 0.75rem;
      color: #94a3b8;
    }
    
    .stat-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 3px;
    }
    
    /* Hero Detail styles - same as before */
    .hero-header {
      background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
      border-radius: 20px;
      padding: 40px;
      margin-bottom: 30px;
      box-shadow: 0 10px 40px rgba(59, 130, 246, 0.3);
    }
    
    .hero-header-content {
      display: flex;
      align-items: center;
      gap: 30px;
      flex-wrap: wrap;
    }
    
    .hero-avatar-large {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
      border: 5px solid rgba(255,255,255,0.2);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    
    .hero-info {
      flex: 1;
    }
    
    .hero-names {
      margin-bottom: 15px;
    }
    
    .hero-name-en-large {
      font-size: 2.5rem;
      font-weight: bold;
      margin-bottom: 5px;
    }
    
    .hero-name-alt-large {
      font-size: 1.2rem;
      color: #60a5fa;
      font-style: italic;
      margin-bottom: 5px;
    }
    
    .hero-name-cn-large {
      font-size: 1.5rem;
      color: #bfdbfe;
    }
    
    .hero-meta {
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      margin-top: 20px;
    }
    
    .meta-badge {
      padding: 8px 16px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.9rem;
    }
    
    .tier-badge-s { background: #dc2626; }
    .tier-badge-a { background: #ea580c; }
    .tier-badge-b { background: #eab308; color: #0f172a; }
    .tier-badge-c { background: #22c55e; }
    .role-badge { background: rgba(255,255,255,0.2); }
    
    .hero-stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      margin-top: 20px;
    }
    
    .stat-box {
      background: rgba(0,0,0,0.2);
      padding: 12px;
      border-radius: 10px;
      text-align: center;
    }
    
    .stat-label {
      font-size: 0.8rem;
      color: #bfdbfe;
      margin-bottom: 5px;
    }
    
    .stat-value {
      font-size: 1.5rem;
      font-weight: bold;
    }
    
    .stat-value.good { color: #4ade80; }
    .stat-value.warning { color: #fbbf24; }
    
    /* Tab Navigation */
    .tab-nav {
      display: flex;
      gap: 10px;
      margin-bottom: 30px;
      background: rgba(30, 41, 59, 0.6);
      padding: 10px;
      border-radius: 15px;
      overflow-x: auto;
    }
    
    .tab-btn {
      padding: 12px 24px;
      border: none;
      background: transparent;
      color: #94a3b8;
      cursor: pointer;
      border-radius: 10px;
      font-weight: 600;
      transition: all 0.3s;
      white-space: nowrap;
    }
    
    .tab-btn:hover {
      background: rgba(51, 65, 85, 0.5);
      color: #e2e8f0;
    }
    
    .tab-btn.active {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      color: white;
    }
    
    /* Tab Content */
    .tab-content {
      display: none;
    }
    
    .tab-content.active {
      display: block;
    }
    
    /* Section Card */
    .section-card {
      background: rgba(30, 41, 59, 0.4);
      border: 2px solid rgba(148, 163, 184, 0.1);
      border-radius: 15px;
      padding: 25px;
      margin-bottom: 20px;
    }
    
    .section-title {
      font-size: 1.5rem;
      font-weight: bold;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    /* Lane Selector */
    .lane-selector {
      display: flex;
      gap: 10px;
      margin-bottom: 25px;
      flex-wrap: wrap;
    }
    
    .lane-btn {
      padding: 10px 20px;
      border: 2px solid #334155;
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.8);
      color: #e2e8f0;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: 600;
    }
    
    .lane-btn:hover {
      border-color: #475569;
      background: rgba(51, 65, 85, 0.8);
    }
    
    .lane-btn.active {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      border-color: #3b82f6;
    }
    
    .lane-btn.primary {
      border-color: #22c55e;
    }
    
    /* Counter Sections */
    .counter-section {
      margin-bottom: 30px;
    }
    
    .counter-section-title {
      font-size: 1.1rem;
      font-weight: bold;
      margin-bottom: 15px;
      padding-bottom: 10px;
      border-bottom: 2px solid #334155;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .counter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 15px;
    }
    
    .counter-card {
      background: linear-gradient(145deg, #1e293b 0%, #0f172a 100%);
      border: 2px solid #334155;
      border-radius: 12px;
      padding: 15px;
      transition: all 0.3s;
      cursor: pointer;
    }
    
    .counter-card:hover {
      border-color: #3b82f6;
      transform: translateY(-2px);
      box-shadow: 0 5px 20px rgba(59, 130, 246, 0.2);
    }
    
    .counter-card.threat {
      border-left: 4px solid #ef4444;
    }
    
    .counter-card.advantage {
      border-left: 4px solid #22c55e;
    }
    
    .counter-hero-info {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
    }
    
    .counter-avatar {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      background: linear-gradient(135deg, #334155 0%, #1e293b 100%);
      border: 2px solid #475569;
    }
    
    .counter-names {
      flex: 1;
    }
    
    .counter-name-en {
      font-weight: bold;
      font-size: 1rem;
      margin-bottom: 2px;
    }
    
    .counter-name-cn {
      font-size: 0.85rem;
      color: #94a3b8;
    }
    
    .counter-tip {
      background: rgba(51, 65, 85, 0.5);
      padding: 10px;
      border-radius: 8px;
      font-size: 0.85rem;
      color: #cbd5e1;
      line-height: 1.5;
    }
    
    .tip-icon {
      color: #fbbf24;
      margin-right: 5px;
    }
    
    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #64748b;
    }
    
    .empty-state-icon {
      font-size: 4rem;
      margin-bottom: 20px;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
      .header h1 {
        font-size: 1.8rem;
      }
      
      .controls {
        flex-direction: column;
      }
      
      .tier-content {
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 10px;
      }
      
      .hero-card {
        padding: 12px;
      }
      
      .hero-avatar {
        width: 60px;
        height: 60px;
        font-size: 1.5rem;
      }
      
      .counter-grid {
        grid-template-columns: 1fr;
      }
      
      .hero-header {
        padding: 25px;
      }
      
      .hero-avatar-large {
        width: 80px;
        height: 80px;
        font-size: 2.5rem;
      }
      
      .hero-name-en-large {
        font-size: 1.8rem;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- TIER LIST VIEW -->
    <div id="view-tierlist" class="view active">
      <div class="header">
        <h1>🎮 HOK English Guide</h1>
        <p>Complete Hero List with Liquipedia + NA Names</p>
        <div class="patch-info">📊 80+ Heroes • Updated March 29, 2026</div>
      </div>

      <div class="controls">
        <div class="search-box">
          <input 
            type="text" 
            id="search-input" 
            placeholder="🔍 Search hero (any name or 中文)..."
            oninput="filterHeroes()"
          >
        </div>
        <div class="filter-buttons">
          <button class="filter-btn active" data-role="all" onclick="filterByRole('all')">All Roles</button>
          <button class="filter-btn" data-role="Tank" onclick="filterByRole('Tank')">Tank</button>
          <button class="filter-btn" data-role="Fighter" onclick="filterByRole('Fighter')">Fighter</button>
          <button class="filter-btn" data-role="Assassin" onclick="filterByRole('Assassin')">Assassin</button>
          <button class="filter-btn" data-role="Mage" onclick="filterByRole('Mage')">Mage</button>
          <button class="filter-btn" data-role="Marksman" onclick="filterByRole('Marksman')">Marksman</button>
          <button class="filter-btn" data-role="Support" onclick="filterByRole('Support')">Support</button>
        </div>
      </div>

      <div id="tier-container"></div>
    </div>

    <!-- HERO DETAIL VIEW -->
    <div id="view-herodetail" class="view">
      <button class="back-btn" onclick="showView('tierlist')">
        ← Back to Tier List
      </button>
      <div id="hero-detail-content"></div>
    </div>
  </div>

  <script>
    // ============================================
    // HERO DATABASE - COMPLETE 80+ ROSTER
    // Liquipedia names (primary) + NA alternates
    // ============================================
    const HEROES = {
      // S-TIER (Meta Defining)
      'jing': {
        id: 'jing',
        nameEn: 'Jing',
        nameEnAlt: 'Mirror',
        nameCn: '镜',
        role: 'Assassin',
        primaryLane: 'Jungle',
        viableLanes: ['Mid'],
        tier: 'S',
        difficulty: 4,
        winRate: 54.2,
        pickRate: 23.0,
        banRate: 45.0,
        avatar: '🗡️',
        counters: {
          jungle: {
            weak: ['lam', 'xuance', 'donghuang', 'caiyan'],
            strong: ['daji', 'angela', 'luban', 'houyi', 'ying']
          },
          mid: {
            weak: ['diaochan', 'yao', 'zhouyu'],
            strong: ['angela', 'ying', 'huangzhong']
          }
        }
      },
      'yao': {
        id: 'yao',
        nameEn: 'Yao',
        nameEnAlt: 'Yaria',
        nameCn: '瑶',
        role: 'Support',
        primaryLane: 'Roam',
        viableLanes: [],
        tier: 'S',
        difficulty: 2,
        winRate: 53.8,
        pickRate: 19.0,
        banRate: 38.0,
        avatar: '🦋'
      },
      'luban': {
        id: 'luban',
        nameEn: 'Luban No.7',
        nameEnAlt: null,
        nameCn: '鲁班七号',
        role: 'Marksman',
        primaryLane: 'Farm',
        viableLanes: [],
        tier: 'S',
        difficulty: 1,
        winRate: 52.9,
        pickRate: 22.0,
        banRate: 15.0,
        avatar: '🤖'
      },
      'daji': {
        id: 'daji',
        nameEn: 'Daji',
        nameEnAlt: null,
        nameCn: '妲己',
        role: 'Mage',
        primaryLane: 'Mid',
        viableLanes: [],
        tier: 'S',
        difficulty: 2,
        winRate: 53.5,
        pickRate: 18.0,
        banRate: 25.0,
        avatar: '🦊'
      },
      'gaochanggong': {
        id: 'gaochanggong',
        nameEn: 'Gao Changgong',
        nameEnAlt: 'Lancelot',
        nameCn: '兰陵王',
        role: 'Assassin',
        primaryLane: 'Jungle',
        viableLanes: ['Mid'],
        tier: 'S',
        difficulty: 3,
        winRate: 52.8,
        pickRate: 20.0,
        banRate: 35.0,
        avatar: '👤'
      },
      'augran': {
        id: 'augran',
