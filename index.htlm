        primaryLane: 'Jungle',
        viableLanes: [],
        tier: 'S',
        difficulty: 2,
        winRate: 52.7,
        pickRate: 17.0,
        banRate: 28.0,
        avatar: '🎯'
      },
      'feyd': {
        id: 'feyd',
        nameEn: 'Feyd',
        nameEnAlt: null,
        nameCn: '费奥',
        role: 'Assassin',
        primaryLane: 'Jungle',
        viableLanes: [],
        tier: 'S',
        difficulty: 3,
        winRate: 52.5,
        pickRate: 16.0,
        banRate: 30.0,
        avatar: '⚡'
      },
      'chicha': {
        id: 'chicha',
        nameEn: 'Chicha',
        nameEnAlt: null,
        nameCn: '姬小满',
        role: 'Fighter',
        primaryLane: 'Baron',
        viableLanes: [],
        tier: 'S',
        difficulty: 2,
        winRate: 52.6,
        pickRate: 15.0,
        banRate: 20.0,
        avatar: '🌸'
      },
      'lam': {
        id: 'lam',
        nameEn: 'Lam',
        nameEnAlt: 'Lan',
        nameCn: '澜',
        role: 'Fighter',
        primaryLane: 'Jungle',
        viableLanes: ['Baron'],
        tier: 'S',
        difficulty: 3,
        winRate: 52.3,
        pickRate: 14.0,
        banRate: 25.0,
        avatar: '🌊'
      },

      // A-TIER (Strong Picks)
      'luna': {
        id: 'luna',
        nameEn: 'Luna',
        nameEnAlt: 'Diana',
        nameCn: '露娜',
        role: 'Fighter',
        primaryLane: 'Jungle',
        viableLanes: ['Baron'],
        tier: 'A',
        difficulty: 3,
        winRate: 51.8,
        pickRate: 18.0,
        banRate: 12.0,
        avatar: '🌙'
      },
      'ukyotachibana': {
        id: 'ukyotachibana',
        nameEn: 'Ukyo Tachibana',
        nameEnAlt: null,
        nameCn: '橘右京',
        role: 'Fighter',
        primaryLane: 'Baron',
        viableLanes: ['Mid', 'Jungle'],
        tier: 'A',
        difficulty: 3,
        winRate: 52.1,
        pickRate: 15.0,
        banRate: 8.0,
        avatar: '⚔️'
      },
      'donghuang': {
        id: 'donghuang',
        nameEn: 'Donghuang',
        nameEnAlt: 'Donghuang Taiyi',
        nameCn: '东皇太一',
        role: 'Tank',
        primaryLane: 'Roam',
        viableLanes: [],
        tier: 'A',
        difficulty: 2,
        winRate: 52.3,
        pickRate: 14.0,
        banRate: 22.0,
        avatar: '🌟'
      },
