        id: 'butterfly',
        nameEn: 'Butterfly',
        nameEnAlt: null,
        nameCn: '露娜（蝶）',
        role: 'Assassin',
        primaryLane: 'Jungle',
        viableLanes: [],
        tier: 'B',
        difficulty: 3,
        winRate: 49.9,
        pickRate: 6.0,
        banRate: 3.0,
        avatar: '🦋'
      },
      'umbrosa': {
        id: 'umbrosa',
        nameEn: 'Umbrosa',
        nameEnAlt: null,
        nameCn: '百里守约（影）',
        role: 'Marksman',
        primaryLane: 'Farm',
        viableLanes: [],
        tier: 'B',
        difficulty: 3,
        winRate: 49.7,
        pickRate: 7.0,
        banRate: 4.0,
        avatar: '🎯'
      },
      'menki': {
        id: 'menki',
        nameEn: 'Menki',
        nameEnAlt: null,
        nameCn: '蒙犽',
        role: 'Marksman',
        primaryLane: 'Farm',
        viableLanes: [],
        tier: 'B',
        difficulty: 2,
        winRate: 49.8,
        pickRate: 6.0,
        banRate: 2.0,
        avatar: '🎯'
      },
      'ming': {
        id: 'ming',
        nameEn: 'Ming',
        nameEnAlt: null,
        nameCn: '明世隐',
        role: 'Support',
        primaryLane: 'Roam',
        viableLanes: [],
        tier: 'B',
        difficulty: 1,
        winRate: 50.2,
        pickRate: 4.0,
        banRate: 2.0,
        avatar: '🔗'
      }
    };

    // ============================================
    // AUTO-GENERATE COUNTERS FOR ALL HEROES
    // Based on role matchups and game mechanics
    // ============================================
    function generateCounters() {
      // Counter rules based on roles and characteristics
      const assassins = Object.values(HEROES).filter(h => h.role === 'Assassin').map(h => h.id);
      const mages = Object.values(HEROES).filter(h => h.role === 'Mage').map(h => h.id);
      const marksmen = Object.values(HEROES).filter(h => h.role === 'Marksman').map(h => h.id);
      const tanks = Object.values(HEROES).filter(h => h.role === 'Tank').map(h => h.id);
      const fighters = Object.values(HEROES).filter(h => h.role === 'Fighter').map(h => h.id);
      const supports = Object.values(HEROES).filter(h => h.role === 'Support').map(h => h.id);

      // Apply counter logic to each hero
      Object.values(HEROES).forEach(hero => {
        if (!hero.counters) {
          hero.counters = {};
        }

        const lanes = [hero.primaryLane.toLowerCase(), ...hero.viableLanes.map(l => l.toLowerCase())];
        
        lanes.forEach(lane => {
          if (!hero.counters[lane]) {
            const weak = [];
            const strong = [];

            // ASSASSINS counter immobile mages/marksmen
            if (hero.role === 'Assassin') {
              strong.push(...mages.filter(m => !['diaochan'].includes(m)).slice(0, 3));
              strong.push(...marksmen.filter(m => !['marcopolo'].includes(m)).slice(0, 2));
              weak.push(...tanks.slice(0, 2));
              weak.push(...supports.filter(s => ['donghuang', 'caiyan', 'yao'].includes(s)));
            }

            // MAGES counter tanks/fighters (poke)
            else if (hero.role === 'Mage') {
              strong.push(...tanks.slice(0, 2));
              strong.push(...fighters.filter(f => !['lam', 'augran'].includes(f)).slice(0, 2));
              weak.push(...assassins.slice(0, 3));
            }

            // MARKSMEN counter tanks (sustained DPS)
            else if (hero.role === 'Marksman') {
              strong.push(...tanks.slice(0, 2));
              strong.push(...fighters.slice(0, 2));
              weak.push(...assassins.slice(0, 4));
            }

            // TANKS counter assassins (peel)
            else if (hero.role === 'Tank') {
              strong.push(...assassins.slice(0, 3));
              weak.push(...mages.filter(m => ['daji', 'angela', 'ying'].includes(m)));
              weak.push(...marksmen.slice(0, 2));
            }

            // FIGHTERS - balanced matchups
            else if (hero.role === 'Fighter') {
              strong.push(...mages.slice(0, 2));
              strong.push(...marksmen.slice(0, 1));
              weak.push(...tanks.slice(0, 2));
              weak.push(...fighters.filter(f => ['lam', 'augran', 'machao'].includes(f)));
            }

            // SUPPORTS - utility based
            else if (hero.role === 'Support') {
              strong.push(...assassins.slice(0, 2));
              weak.push(...tanks.slice(0, 1));
              weak.push(...mages.filter(m => ['daji', 'angela'].includes(m)));
            }

            // Remove duplicates and self
            hero.counters[lane] = {
              weak: [...new Set(weak)].filter(id => id !== hero.id).slice(0, 4),
              strong: [...new Set(strong)].filter(id => id !== hero.id).slice(0, 4)
            };
          }
        });
      });
    }

    // Generate counters on load
    generateCounters();

    // Counter tips database
    const COUNTER_TIPS = {
      'default': 'Strong matchup based on role advantage.',
      'assassin_vs_mage': 'High mobility allows easy assassination of immobile mages.',
      'assassin_vs_marksman': 'Burst damage kills squishy marksmen before they can react.',
      'tank_vs_assassin': 'High HP and CC shuts down assassin burst combos.',
      'mage_vs_tank': 'Percent damage and poke wears down tanks over time.',
      'marksman_vs_tank': 'Sustained DPS shreds through tank HP.',
      'support_anti_burst': 'Healing and shields counter burst assassins.'
    };

    function getCounterTip(attackerId, defenderId) {
      const attacker = HEROES[attackerId];
      const defender = HEROES[defenderId];
      
      if (!attacker || !defender) return COUNTER_TIPS['default'];
      
      const key = `${attacker.role.toLowerCase()}_vs_${defender.role.toLowerCase()}`;
      return COUNTER_TIPS[key] || COUNTER_TIPS['default'];
    }

    // State
    let currentFilter = 'all';
    let currentSearch = '';
    let currentView = 'tierlist';
    let currentHero = null;
    let currentTab = 'counters';
    let currentLane = null;

    // Initialize
    function init() {
      renderAllTiers();
    }

    // View management
    function showView(viewName, heroId = null) {
      document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
      document.getElementById('view-' + viewName).classList.add('active');
      currentView = viewName;

      if (viewName === 'herodetail' && heroId) {
        currentHero = HEROES[heroId];
        renderHeroDetail();
      }
    }

    // Render all tiers
    function renderAllTiers() {
      const container = document.getElementById('tier-container');
      container.innerHTML = '';
      
      ['S', 'A', 'B', 'C'].forEach(tier => {
        const section = createTierSection(tier);
        container.appendChild(section);
      });
    }

    // Create tier section
    function createTierSection(tier) {
      const section = document.createElement('div');
      section.className = 'tier-section';
      section.dataset.tier = tier;
      
      const label = {
        'S': 'Meta Defining',
        'A': 'Strong Picks',
        'B': 'Balanced',
        'C': 'Situational'
      }[tier];
      
      const icon = {
        'S': '🏆',
        'A': '⭐',
        'B': '💫',
        'C': '✨'
      }[tier];
      
      section.innerHTML = `
        <div class="tier-header tier-${tier.toLowerCase()}">
          <span>${icon}</span>
          <span>${tier}-TIER</span>
          <span style="font-size: 0.9rem; font-weight: normal; margin-left: auto;">${label}</span>
        </div>
        <div class="tier-content" id="tier-${tier.toLowerCase()}-content"></div>
      `;
      
      renderTier(tier);
      return section;
    }

    // Render specific tier
    function renderTier(tier) {
      const container = document.getElementById(`tier-${tier.toLowerCase()}-content`);
      const heroes = Object.values(HEROES).filter(h => {
        const matchesTier = h.tier === tier;
        const matchesRole = currentFilter === 'all' || h.role === currentFilter;
        const matchesSearch = currentSearch === '' || 
          h.nameEn.toLowerCase().includes(currentSearch) ||
          (h.nameEnAlt && h.nameEnAlt.toLowerCase().includes(currentSearch)) ||
          h.nameCn.includes(currentSearch) ||
          h.role.toLowerCase().includes(currentSearch);
        return matchesTier && matchesRole && matchesSearch;
      });

      if (heroes.length === 0) {
        container.innerHTML = '<div class="empty-state"><div class="empty-state-icon">🔍</div><p>No heroes found in this tier</p></div>';
        return;
      }

      container.innerHTML = heroes.map(hero => createHeroCard(hero)).join('');
    }

    // Create hero card HTML
    function createHeroCard(hero) {
      const altName = hero.nameEnAlt ? `<div class="hero-name-alt">${hero.nameEnAlt}</div>` : '';
      return `
        <div class="hero-card" onclick="showView('herodetail', '${hero.id}')">
          <div class="hero-avatar">${hero.avatar}</div>
          <div class="hero-name-en">${hero.nameEn}</div>
          ${altName}
          <div class="hero-name-cn">${hero.nameCn}</div>
          <div class="hero-role role-${hero.role.toLowerCase()}">${hero.role}</div>
          <div class="hero-stats">
            <div class="stat-row">
              <span>WR:</span>
              <span style="color: ${hero.winRate >= 50 ? '#4ade80' : '#f87171'}">${hero.winRate}%</span>
            </div>
            <div class="stat-row">
              <span>PR:</span>
              <span>${hero.pickRate}%</span>
            </div>
            <div class="stat-row">
              <span>BR:</span>
              <span>${hero.banRate}%</span>
            </div>
          </div>
        </div>
      `;
    }

    // Filter by role
    function filterByRole(role) {
      currentFilter = role;
      
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      document.querySelector(`[data-role="${role}"]`).classList.add('active');
      
      ['S', 'A', 'B', 'C'].forEach(tier => renderTier(tier));
    }

    // Filter heroes by search
    function filterHeroes() {
      currentSearch = document.getElementById('search-input').value.toLowerCase();
      ['S', 'A', 'B', 'C'].forEach(tier => renderTier(tier));
    }

    // Render hero detail page
    function renderHeroDetail() {
      if (!currentHero) return;
      
      const h = currentHero;
      const tierClass = `tier-badge-${h.tier.toLowerCase()}`;
      const altNameHtml = h.nameEnAlt ? `<div class="hero-name-alt-large">${h.nameEnAlt}</div>` : '';
      
      // Get available lanes with counters
      const availableLanes = Object.keys(h.counters || {});
      const hasCounters = availableLanes.length > 0;
      
      document.getElementById('hero-detail-content').innerHTML = `
        <div class="hero-header">
          <div class="hero-header-content">
            <div class="hero-avatar-large">${h.avatar}</div>
            <div class="hero-info">
              <div class="hero-names">
                <div class="hero-name-en-large">${h.nameEn}</div>
                ${altNameHtml}
                <div class="hero-name-cn-large">${h.nameCn}</div>
              </div>
              <div class="hero-meta">
                <span class="meta-badge ${tierClass}">${h.tier}-TIER</span>
                <span class="meta-badge role-badge">${h.role}</span>
                <span class="meta-badge role-badge">Difficulty: ${'⭐'.repeat(h.difficulty)}${'☆'.repeat(5-h.difficulty)}</span>
              </div>
              <div class="hero-stats-grid">
                <div class="stat-box">
                  <div class="stat-label">Win Rate</div>
                  <div class="stat-value ${h.winRate >= 52 ? 'good' : h.winRate >= 48 ? '' : 'bad'}">${h.winRate}%</div>
                </div>
                <div class="stat-box">
                  <div class="stat-label">Pick Rate</div>
                  <div class="stat-value">${h.pickRate}%</div>
                </div>
                <div class="stat-box">
                  <div class="stat-label">Ban Rate</div>
                  <div class="stat-value ${h.banRate >= 30 ? 'warning' : ''}">${h.banRate}%</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        ${hasCounters ? renderCountersSection(h, availableLanes) : renderNoCounters()}
      `;
    }

    // Render counters section
    function renderCountersSection(hero, availableLanes) {
      const firstLane = availableLanes[0];
      currentLane = currentLane && availableLanes.includes(currentLane) ? currentLane : firstLane;
      
      const laneButtons = availableLanes.map(lane => {
        const isPrimary = lane === hero.primaryLane.toLowerCase();
        const active = lane === currentLane ? 'active' : '';
        const primaryClass = isPrimary ? 'primary' : '';
        const laneLabel = {
          'jungle': '🌲 Jungle',
          'baron': '👑 Baron',
          'mid': '⭐ Mid',
          'farm': '💰 Farm',
          'roam': '🌍 Roam'
        }[lane] || lane;
        
        return `<button class="lane-btn ${active} ${primaryClass}" onclick="selectHeroLane('${lane}')">${laneLabel}${isPrimary ? ' (Primary)' : ''}</button>`;
      }).join('');

      const counters = hero.counters[currentLane];
      
      return `
        <div class="section-card">
          <div class="section-title">
            <span>🎯</span>
            <span>Lane-Specific Counters</span>
          </div>

          <div class="lane-selector">
            ${laneButtons}
          </div>

          ${renderLaneCounters(hero, currentLane, counters)}
        </div>
      `;
    }

    // Render lane counters
    function renderLaneCounters(hero, lane, counters) {
      if (!counters) return '<p>No counter data available for this lane.</p>';
      
      let html = '';
      
      // Threats
      if (counters.weak && counters.weak.length > 0) {
        html += `
          <div class="counter-section">
            <div class="counter-section-title">
              <span>⚔️</span>
              <span>Heroes That Counter ${hero.nameEn} (${lane.charAt(0).toUpperCase() + lane.slice(1)})</span>
              <span style="margin-left: auto; font-size: 0.9rem; color: #94a3b8;">Pick these against ${hero.nameEn}</span>
            </div>
            <div class="counter-grid">
              ${counters.weak.map(cid => renderCounterCard(cid, 'threat', hero.id)).join('')}
            </div>
          </div>
        `;
      }
      
      // Advantages
      if (counters.strong && counters.strong.length > 0) {
        html += `
          <div class="counter-section">
            <div class="counter-section-title">
              <span>✅</span>
              <span>${hero.nameEn} Strong Against (${lane.charAt(0).toUpperCase() + lane.slice(1)})</span>
              <span style="margin-left: auto; font-size: 0.9rem; color: #94a3b8;">${hero.nameEn} counters these</span>
            </div>
            <div class="counter-grid">
              ${counters.strong.map(cid => renderCounterCard(cid, 'advantage', hero.id)).join('')}
            </div>
          </div>
        `;
      }
      
      return html;
    }

    // Render counter card
    function renderCounterCard(heroId, type, referenceId) {
      const counter = HEROES[heroId];
      if (!counter) return '';
      
      const tip = getCounterTip(type === 'threat' ? heroId : referenceId, type === 'threat' ? referenceId : heroId);
      const altName = counter.nameEnAlt ? `<div class="counter-name-cn" style="color: #60a5fa; font-style: italic;">${counter.nameEnAlt}</div>` : '';
      
      return `
        <div class="counter-card ${type}" onclick="showView('herodetail', '${heroId}')">
          <div class="counter-hero-info">
            <div class="counter-avatar">${counter.avatar}</div>
            <div class="counter-names">
              <div class="counter-name-en">${counter.nameEn}</div>
              ${altName}
              <div class="counter-name-cn">${counter.nameCn}</div>
            </div>
          </div>
          <div class="counter-tip">
            <span class="tip-icon">💡</span>
            ${tip}
          </div>
        </div>
      `;
    }

    // Render no counters placeholder
    function renderNoCounters() {
      return `
        <div class="section-card" style="text-align: center; padding: 40px;">
          <div style="font-size: 3rem; margin-bottom: 20px;">🚧</div>
          <h2 style="margin-bottom: 10px;">Counter Data Coming Soon!</h2>
          <p style="color: #94a3b8;">Counter data for this hero will be added soon.</p>
        </div>
      `;
    }

    // Select hero lane
    function selectHeroLane(lane) {
      currentLane = lane;
      renderHeroDetail();
    }

    // Initialize on load
    init();
  </script>
</body>
</html>
